# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=app
DB_PASSWORD=change_me_in_production
DB_NAME=url_monitor

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_random_32_byte_secret
JWT_TTL=24h

# Kafka
KAFKA_BROKERS=kafka:29092

# Service addresses (within Docker network)
AUTH_SERVICE_ADDR=auth-service:50051
URL_SERVICE_ADDR=url-service:50052
ANALYTICS_SERVICE_ADDR=analytics-service:50053

# Monitor settings
POLL_INTERVAL=30s
HTTP_TIMEOUT=10s
MAX_CONCURRENCY=10
